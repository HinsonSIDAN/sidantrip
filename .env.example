# LLM Provider Keys (at least one required)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# Default model (uses LiteLLM format)
# Examples: anthropic/claude-sonnet-4-20250514, gpt-4o, gemini/gemini-2.5-flash
SIDANTRIP_LLM_MODEL=anthropic/claude-sonnet-4-20250514

# Redis (for async job queue)
REDIS_URL=redis://localhost:6379

# Activity database path
SIDANTRIP_DB_PATH=../sidantrip-db

# Server
PORT=8001
